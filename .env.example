# =============================================================
# Root .env — used by docker-compose.yml
# Copy to .env and fill in the values before running:
#   cp .env.example .env
# =============================================================

# ---- Backend ------------------------------------------------
NODE_ENV=production
PORT=5000

# MongoDB connection (use Atlas URI in production)
MONGODB_URI=mongodb://mongo:27017/expense_tracker

# JWT — minimum 32 characters, keep secret
JWT_SECRET=change-this-to-a-long-random-secret-min-32-chars
JWT_EXPIRE=7d

# Frontend origin (used for CORS)
CLIENT_URL=http://localhost:3000

# ---- AI Service ---------------------------------------------
# Must match the value set in the AI service container
AI_SERVICE_URL=http://ai-service:8000
AI_SERVICE_KEY=internal-key

# ---- Frontend -----------------------------------------------
# Passed as a build-arg to the React container
REACT_APP_API_URL=http://localhost:5000/api
